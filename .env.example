# OpenAI Configuration
# Option 1: Standard OpenAI (recommended)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Option 2: Azure OpenAI (set both to enable Azure mode)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-nano

# Environment configuration
ENVIRONMENT=localhost  # Change to dev, preprod, prod in respective environments
